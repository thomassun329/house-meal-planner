rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/{householdId} {
      // Allow all authenticated users to read household data
      allow read: if request.auth != null;

      // Meal entries: users can only edit their own
      match /mealEntries/{entryId} {
        // Anyone in the household can read
        allow read: if request.auth != null;
        // Users can create/update their own entries, or if admin
        allow create, update: if request.auth != null;
        // Only admin or owner can delete
        allow delete: if request.auth != null;
      }

      // Members: all can read, only admin can modify
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // Settings: all can read, only admin can modify
      match /settings/{doc=**} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }
    }
  }
}
